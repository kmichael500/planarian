{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "AppConfigConnectionString": "APP_CONFIG_CONNECTION_STRING"
  },
  "Server": {
    "SqlConnectionString": "SQL_CONNECTION_STRING"
  },
  "Auth": {
    "JwtSecret": "RANDOM_CHARACTERS",
    "JwtIssuer": "JST_ISSUER"
  },
  "Blob": {
    "ConnectionString": "BLOB_CONNECTION_STRING",
    "ContainerName": "CONTAINER_NAME"
  },
  "File": {
    "ConnectionString": "FILE_CONNECTION_STRING",
    "TempExpirationHours": 2
  },
  "Backup": {
    "BlobDownloadTransferConcurrency": 8,
    "BlobDownloadTransferSizeMb": 8,
    "TempBlobCleanupIntervalMinutes": 30,
    "TempDirectory": null
  }
}